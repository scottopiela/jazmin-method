{
  "version": 2,
  "rewrites": [
    { "source": "/thank-you", "destination": "/thank-you.html" },
    { "source": "/course", "destination": "/course.html" },
    { "source": "/video", "destination": "/video.html" },
    { "source": "/audio", "destination": "/audio.html" },
    { "source": "/download", "destination": "/download.html" },
    { "source": "/email/day-2", "destination": "/email-day-02.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }
      ]
    }
  ]
}
