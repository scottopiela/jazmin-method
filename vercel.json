{
  "version": 2,
  "builds": [
    { "src": "*.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/thank-you", "dest": "/thank-you.html" },
    { "src": "/course", "dest": "/course.html" },
    { "src": "/video", "dest": "/video.html" },
    { "src": "/audio", "dest": "/audio.html" },
    { "src": "/download", "dest": "/download.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }
      ]
    }
  ]
}
